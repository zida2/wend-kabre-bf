# ─── Firebase (client, exposées au navigateur — normal) ──────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# Optionnel (Analytics) — référencé par src/lib/firebase.js
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ─── Scraper / cron ──────────────────────────────────────────────────
# Secret serveur pour déclencher /api/scrape en curl (à garder privé).
SCRAPER_SECRET=
# Jeton PUBLIC (exposé au client) pour le bouton "Forcer le scraper" de la
# console admin. Peu sensible : ne fait que lancer un scrape de flux RSS publics.
NEXT_PUBLIC_SCRAPER_SECRET=
# Secret du cron Vercel. Vercel envoie automatiquement
# `Authorization: Bearer <CRON_SECRET>` aux routes planifiées.
CRON_SECRET=

# ─── Email (nodemailer / Gmail) — optionnel ──────────────────────────
EMAIL_USER=
EMAIL_APP_PASSWORD=
