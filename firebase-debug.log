[debug] [2026-06-30T15:47:19.827Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/wend-kabre-bf-2026/rulesets {"name":"projects/wend-kabre-bf-2026/rulesets/0c5c565b-3f4c-433a-8ec5-f27f7f40c6c6","source":{"files":[{"content":"rules_version = '2';\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    // ── Marchés publics : lecture libre, écriture par tous (scraper + admin)\n    match /marches/{marchId} {\n      allow read: if true;\n      allow write: if true;\n    }\n\n    // ── Profils utilisateurs : lecture libre, écriture libre (pour l'admin et les PME)\n    match /users/{userId} {\n      allow read, write: if true;\n    }\n\n    // ── Candidatures : accessibles uniquement par l'utilisateur propriétaire\n    match /candidatures/{candidatureId} {\n      allow read:   if request.auth != null && request.auth.uid == resource.data.userId;\n      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;\n      allow update, delete: if request.auth != null && request.auth.uid == resource.data.userId;\n    }\n\n    // ── Propriétés (héritage ancien projet — conservé)\n    match /properties/{propertyId} {\n      allow read: if true;\n      allow create: if request.resource.data.title != null\n                    && request.resource.data.price != null\n                    && request.resource.data.ownerId != null;\n      allow update: if request.resource.data.ownerId == resource.data.ownerId;\n      allow delete: if true;\n    }\n    // ── Demandes de paiement : lecture et écriture libres pour la gestion\n    match /payment_requests/{requestId} {\n      allow read, write: if true;\n    }\n  }\n}\n","name":"firestore.rules"}]},"createTime":"2026-06-30T15:47:20.103567Z","metadata":{"services":["cloud.firestore"]}}
